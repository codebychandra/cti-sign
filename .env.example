# Copy to .env and fill in. Only VITE_* vars are exposed to the browser.
# The anon key is public-safe by design; never put the service_role key here.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Base path for the built site. GitHub Pages: /<repo-name>/  (e.g. /cti-sign/)
# Custom domain root: /
VITE_BASE=/cti-sign/
